# Kopiera till .env och fyll i. .env committas ALDRIG (se .gitignore).
DATABASE_URL=postgres://user:pass@host/dbname
ANTHROPIC_API_KEY=sk-ant-...
NASS_API_KEY=                     # gratis: https://quickstats.nass.usda.gov/api
USER_AGENT=brookingsview.com (contact: hello@brookingsview.com)
PAGES_DEPLOY_HOOK=                # från Cloudflare Pages > Settings > Deploy hooks
ALERT_WEBHOOK=                    # valfri Slack/Discord/mejl-webhook för scraper-larm
AI_BUDGET_STATE=.ai_budget.json
