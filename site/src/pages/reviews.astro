---
/** Arkiv för media_recension -- dagens recension flyttar hit dagen efter att den
 *  varit ettan på förstasidan (se index.astro / getTodaysFeature). */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionRule from '../components/SectionRule.astro';
import StoryCard from '../components/StoryCard.astro';
import { getContentByType } from '../lib/db';
import { siteConfig } from '../lib/site-config';

const stories = await getContentByType(['media_recension'], 60);
---
<BaseLayout title={`Reviews — ${siteConfig.siteName}`} wide
  description="Reviews of what's currently playing, AI-written and clearly labeled as such.">
  <header class="lede">
    <h1>Reviews</h1>
    <p>Reviews of what's currently in theaters, written by AI and disclosed as such
    on every piece below.</p>
  </header>

  <SectionRule label="Latest" />
  {stories.length > 0 ? (
    <div class="grid">{stories.map((story) => <StoryCard story={story} />)}</div>
  ) : (
    <p class="empty">Nothing published yet.</p>
  )}
</BaseLayout>

<style>
.lede { max-width: 40rem; }
.lede p { color: var(--ink-soft); margin: 0.75rem 0 0; }
.grid { display: grid; gap: 0.75rem; grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr)); }
.empty { color: var(--ink-soft); }
</style>
