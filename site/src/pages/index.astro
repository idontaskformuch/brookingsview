---
/**
 * Startsidan, byggd kring TID i stället för ämne.
 *
 * De flesta lokalsajter sorterar efter kategori (Sport / Politik / Nöje). Men
 * frågan sajten svarar på -- "what's happening in Brookings?" -- handlar om när,
 * inte om vad. Därför: I dag -> Den här veckan -> Runt om i stan.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionRule from '../components/SectionRule.astro';
import StoryCard from '../components/StoryCard.astro';
import GameCard from '../components/GameCard.astro';
import Tile from '../components/Tile.astro';
import {
  getUpcomingStories, getActiveAlerts, getUpcomingGames,
  getWeather, getAgPrices,
} from '../lib/db';

const [alerts, upcoming, games, periods, prices] = await Promise.all([
  getActiveAlerts(),
  getUpcomingStories(['event', 'meeting'], 24),
  getUpcomingGames(4),
  getWeather(),
  getAgPrices(),
]);

const today = periods.find((p) => p.is_daytime) ?? periods[0] ?? null;

const startOfDay = new Date(); startOfDay.setHours(0, 0, 0, 0);
const endOfDay = new Date(startOfDay); endOfDay.setDate(endOfDay.getDate() + 1);
const weekEnd = new Date(startOfDay); weekEnd.setDate(weekEnd.getDate() + 8);

const isWithin = (iso: string | null, from: Date, to: Date) =>
  !!iso && new Date(iso) >= from && new Date(iso) < to;

const todayStories = upcoming.filter((s) => isWithin(s.occurs_at, startOfDay, endOfDay));
const weekStories = upcoming.filter((s) => isWithin(s.occurs_at, endOfDay, weekEnd));
const laterStories = upcoming.filter((s) => s.occurs_at && new Date(s.occurs_at) >= weekEnd);

const nextGame = games[0] ?? null;
const priceLine = prices
  .map((p) => `${p.commodity} ${p.price !== null ? Number(p.price).toFixed(2) : '—'}`)
  .join('   ');
---

<BaseLayout title="Brookings View — what's happening in Brookings, SD" wide>
  <header class="lede">
    <h1>What's happening in Brookings</h1>
    <p>
      Meetings, events, Jackrabbits games, weather and market prices — gathered
      every hour from public sources, with a link back to every one.
    </p>
  </header>

  {alerts.length > 0 && (
    <section aria-label="Active alerts">
      <SectionRule label="Right now" />
      <div class="stack">
        {alerts.map((story) => <StoryCard story={story} />)}
      </div>
    </section>
  )}

  <section aria-label="Today">
    <SectionRule label="Today" />
    <div class="grid grid--tiles">
      {today && (
        <Tile
          label="Weather"
          value={`${today.temp !== null ? Math.round(today.temp) : '—'}°${today.unit}`}
          note={today.short}
        />
      )}
      <Tile
        label="Happening today"
        value={String(todayStories.length)}
        note={todayStories.length === 1 ? 'event or meeting' : 'events and meetings'}
      />
      {prices.length > 0 && (
        <Tile label="Markets" value={prices.length === 0 ? '—' : `${prices.length}`} note={priceLine} />
      )}
    </div>
    {todayStories.length > 0 && (
      <div class="stack stack--top">
        {todayStories.map((story) => <StoryCard story={story} />)}
      </div>
    )}
  </section>

  <section aria-label="This week">
    <SectionRule label="This week" href="/events" />
    {nextGame && (
      <div class="feature">
        <GameCard game={nextGame} feature />
      </div>
    )}
    {weekStories.length > 0 ? (
      <div class="grid grid--cards">
        {weekStories.map((story) => <StoryCard story={story} />)}
      </div>
    ) : (
      <p class="empty">Nothing scheduled in the next week yet. Check back — this
      page rebuilds every hour.</p>
    )}
  </section>

  {laterStories.length > 0 && (
    <section aria-label="Coming up">
      <SectionRule label="Coming up" href="/events" />
      <div class="grid grid--cards">
        {laterStories.slice(0, 6).map((story) => <StoryCard story={story} compact />)}
      </div>
    </section>
  )}

  <section aria-label="Around town">
    <SectionRule label="Around town" />
    <div class="grid grid--cards">
      <a class="panel" href="/jackrabbits">
        <h3>Jackrabbits</h3>
        <p>Full schedules and results for SDSU football, basketball and volleyball.</p>
      </a>
      <a class="panel" href="/city-hall">
        <h3>City hall</h3>
        <p>What the city council, county commission and committees are deciding.</p>
      </a>
      <a class="panel" href="/farm-report">
        <h3>Farm report</h3>
        <p>Corn, soybean and cattle prices from USDA.</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
.lede { max-width: 40rem; margin-bottom: 0.5rem; }
.lede p { color: var(--ink-soft); font-size: 1.125rem; margin: 0.75rem 0 0; }

.stack { display: grid; gap: 0.75rem; }
.stack--top { margin-top: 1rem; }

.grid { display: grid; gap: 0.75rem; }
.grid--tiles { grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); }
.grid--cards { grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr)); }

.feature { margin-bottom: 0.75rem; }

.empty {
  color: var(--ink-soft);
  background: var(--surface);
  border: 1px dashed var(--rule);
  border-radius: 4px;
  padding: 1.25rem;
  margin: 0;
}

.panel {
  display: block;
  background: var(--surface);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 1.125rem 1.25rem;
  text-decoration: none;
  color: inherit;
}
.panel:hover { border-color: var(--sky); }
.panel h3 { margin: 0 0 0.375rem; color: var(--sky); }
.panel p { margin: 0; font-size: 0.9375rem; color: var(--ink-soft); }
</style>
