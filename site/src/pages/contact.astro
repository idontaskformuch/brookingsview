---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site-config';

const isBrookings = siteConfig.townId === 'brookings_sd';
---
<BaseLayout title={`Contact — ${siteConfig.siteName}`} description={`Get in touch with ${siteConfig.siteName}.`}>
  <article class="prose">
    <h1>Contact</h1>
    <p>Spotted a mistake, know about an event we're missing, or just want to
    say hello? Email <a href={`mailto:${siteConfig.removalEmail}`}>{siteConfig.removalEmail}</a>.</p>

    <h2>Corrections</h2>
    <p>Tell us what's wrong and where you saw it — a link to the page helps.
    Most corrections go live within the hour.</p>

    <h2>Missing an event?</h2>
    <p>If your organization runs public events in {siteConfig.cityName} and you'd like them
    included, get in touch. Right now the site covers the library, the city and
    county{isBrookings ? ', and SDSU athletics' : ''} — we're always looking to add more.</p>
  </article>
</BaseLayout>

<style>
.prose { max-width: 36rem; }
.prose h2 { margin-top: 2rem; margin-bottom: 0.5rem; }
.prose p { margin: 0 0 1rem; }
</style>
