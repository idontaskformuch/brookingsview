---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site-config';
---
<BaseLayout title={`You're offline — ${siteConfig.siteName}`} description="No connection right now.">
  <h1>You're offline</h1>
  <p>{siteConfig.siteName} needs a connection to load new stories. Reconnect and try again — pages you've already
  visited may still be available.</p>
</BaseLayout>
