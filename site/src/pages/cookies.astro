---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site-config';
---
<BaseLayout title={`Cookies — ${siteConfig.siteName}`} description={`${siteConfig.siteName}'s current cookie use.`}>
  <article class="prose">
    <h1>Cookies</h1>
    <p><em>Last updated July 2026.</em></p>

    <p>{siteConfig.siteName} does not currently set any tracking or advertising
    cookies. Cloudflare, our hosting provider, may use a small number of
    strictly necessary cookies to keep the site secure and running smoothly;
    these aren't used to track you across other sites.</p>

    <p>If that changes — for instance, if the site starts showing
    advertising — this page will be updated first, and you'll be asked for
    consent where required.</p>

    <p>Questions? <a href="/contact">Contact us</a>.</p>
  </article>
</BaseLayout>

<style>
.prose { max-width: 36rem; }
.prose p { margin: 0 0 1rem; }
</style>
