---
/** Enskild story. Varje sida länkar tillbaka till sin primärkälla -- det är både
 *  hederligt mot läsaren och det som gör E-E-A-T-anspråket på metodsidan sant. */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedStories from '../../components/RelatedStories.astro';
import Byline from '../../components/Byline.astro';
import { getAllStories, getRelatedStories, formatOccursAt, formatDate, CATEGORY_LABELS } from '../../lib/db';
import type { Story } from '../../lib/db';
import { siteConfig } from '../../lib/site-config';

export async function getStaticPaths() {
  const stories = await getAllStories();
  return stories.map((story) => ({ params: { slug: story.slug }, props: { story } }));
}

const { story } = Astro.props as { story: Story };
const isAlert = story.source_type === 'alert';
const kind = isAlert ? 'Alert' : story.source_type === 'meeting' ? 'Meeting' : 'Event';
// Genererat innehåll (krönikor m.fl.) har alltid byline satt -- scraped nyheter
// har byline = NULL. Byline.astro ersätter story__kind-raden när den finns, i
// stället för att visa båda (kind skulle ändå bara säga "Event" fel för dessa).
const hasByline = Boolean(story.byline);
const category = CATEGORY_LABELS[story.source_type] ?? story.source_type;
const when = hasByline ? null : (formatOccursAt(story) || null);
const canonicalUrl = new URL(`/s/${story.slug}/`, Astro.site ?? siteConfig.siteUrl).href;
const related = await getRelatedStories(story, 3);
// Steg 3.5: en tecknad illustration matchad till artikeln, om en sådan finns.
// Har inte samma mått som OG-korten (1200x630) -- inga hårdkodade width/height
// för den, bara CSS-skalning. Saknas image_path (scraped content, eller om
// bildgenereringen misslyckades den dagen) faller sidan tillbaka på OG-kortet.
const heroSrc = story.image_path ?? `/og/${story.slug}.png`;
const heroUrl = new URL(heroSrc, Astro.site ?? siteConfig.siteUrl).href;
---

<BaseLayout title={`${story.title} — ${siteConfig.siteName}`} description={story.body.slice(0, 155)} ogSlug={story.slug}>
  <article class="story">
    {!hasByline && <p class="story__kind data">{kind}</p>}
    <h1>{story.title}</h1>
    {hasByline && (
      <Byline category={category} byline={story.byline!} date={formatDate(story.published_at)} />
    )}
    {when && <p class="story__when data">{when}</p>}

    <img
      class="story__hero"
      src={heroSrc}
      alt={`Illustration for “${story.title}”`}
      loading="eager"
    />

    <div class="story__body">
      {story.body.split('\n').filter(Boolean).map((para) => <p>{para}</p>)}
    </div>

    <ShareButtons url={canonicalUrl} title={story.title} />

    <footer class="story__source">
      {story.source_url ? (
        <p>
          Source: <a href={story.source_url} rel="noopener">the original agenda or listing</a>.
          Read it if you need the full detail — this summary is deliberately short.
        </p>
      ) : (
        <p>{siteConfig.sourceBlurb}</p>
      )}
      <p class="data">
        Published {formatDate(story.published_at)} ·
        <a href="/how-we-gather-this">How we gather this</a>
      </p>
    </footer>
  </article>

  <RelatedStories stories={related} />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: story.title,
    datePublished: story.published_at,
    dateModified: story.published_at,
    articleBody: story.body,
    image: [heroUrl],
    // story.byline är alltid den bokstavliga strängen "AI-genererad" (se
    // content/_base.py:to_metadata) -- en transparensmarkering, inte ett
    // riktigt namn. Att sätta '@type':'Person', name:'AI-genererad' skulle
    // hävda att en person med det namnet skrev texten, exakt den sortens
    // påhittade uppgift projektets egna regler annars aldrig tillåter.
    // Ingen story har en riktig mänsklig författare i nuläget, så
    // Organization gäller för alla.
    author: { '@type': 'Organization', name: siteConfig.siteName },
    publisher: { '@type': 'Organization', name: siteConfig.siteName },
  })} />
</BaseLayout>

<style>
.story { max-width: 38rem; }
.story__kind {
  margin: 0 0 0.5rem;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--navy);
}
.story__when { margin: 0.75rem 0 0; color: var(--ink-soft); font-size: 0.875rem; }
.story__hero {
  display: block;
  width: 100%;
  height: auto;
  margin-top: 1.25rem;
  border-bottom: 1px solid var(--rule);
  padding-bottom: 1.25rem;
}
.story__body { margin-top: 1.75rem; font-size: 1.125rem; }
.story__body p { margin: 0 0 1rem; }
.story__source {
  margin-top: 2.5rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--rule);
  font-size: 0.9375rem;
  color: var(--ink-soft);
}
.story__source p { margin: 0 0 0.5rem; }
.story__source .data { font-size: 0.8125rem; }
</style>
