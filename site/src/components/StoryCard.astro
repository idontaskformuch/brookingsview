---
/** En post i nyhetsströmmen. Avdelad med hårfin linje, inte inramad som ett
 *  kort -- kortramar plattar ut hierarkin och får allt att se lika viktigt ut. */
import type { Story } from '../lib/db';
import { formatDate, formatTime, formatCalendarDate, CATEGORY_LABELS } from '../lib/db';

interface Props { story: Story; compact?: boolean; }
const { story, compact = false } = Astro.props;

const isAlert = story.source_type === 'alert';
const isMeeting = story.source_type === 'meeting';
// Content Track-innehåll (krönikor, recensioner, recept m.fl.) har alltid byline
// satt -- occurs_at är bara now() vid genereringstillfället för de typerna, så
// den ska aldrig användas som tidsangivelse. Publiceringsdatum är den rätta.
const hasByline = Boolean(story.byline);
const when = story.occurs_at;
const timeLabel = hasByline
  ? formatDate(story.published_at)
  : !when
    ? ''
    : isMeeting
      ? formatCalendarDate(when)  // datum-utan-klockslag -- se db.ts
      : `${formatDate(when)}${!isAlert && formatTime(when) ? ` · ${formatTime(when)}` : ''}`;

const kicker = isAlert ? 'Alert' : isMeeting ? 'City hall'
  : hasByline ? (CATEGORY_LABELS[story.source_type] ?? 'Feature') : 'Events';
---
<article class:list={['item', isAlert && 'item--alert']}>
  {!compact && story.image_path && (
    <a class="item__image-link" href={`/s/${story.slug}`} tabindex="-1" aria-hidden="true">
      <img class="item__image" src={story.image_path} alt="" loading="lazy" />
    </a>
  )}
  <p class="item__kicker">
    <span class="kicker">{kicker}</span>
    {timeLabel && <span class="item__when data">{timeLabel}</span>}
  </p>
  <h3 class="item__title"><a href={`/s/${story.slug}`}>{story.title}</a></h3>
  {!compact && <p class="item__body">{story.body}</p>}
</article>

<style>
.item {
  border-bottom: 1px solid var(--rule);
  padding-block: 0.875rem;
}
.item:first-child { padding-top: 0; }
.item--alert {
  border-left: 4px solid var(--alert);
  background: var(--alert-tint);
  padding: 0.875rem 1rem;
  border-bottom: 0;
  margin-bottom: 0.75rem;
}
.item--alert .kicker { color: var(--alert); }

.item__image-link { display: block; margin-bottom: 0.5rem; }
.item__image { display: block; width: 100%; height: auto; }

.item__kicker {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.5rem 0.75rem;
  margin: 0 0 0.3125rem;
}
.item__when {
  font-size: 0.6875rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.item__title { margin: 0; font-size: 1.1875rem; line-height: 1.15; }
.item__title a { color: inherit; text-decoration: none; }
.item__title a:hover { color: var(--navy); text-decoration: underline; }
.item__body {
  margin: 0.375rem 0 0;
  font-size: 0.9375rem;
  line-height: 1.5;
  color: var(--ink-soft);
}
</style>
