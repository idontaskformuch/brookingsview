---
import type { Story } from '../lib/db';
import { formatDate, formatTime, formatCalendarDate } from '../lib/db';

interface Props { story: Story; compact?: boolean; }
const { story, compact = false } = Astro.props;

const isAlert = story.source_type === 'alert';
const isMeeting = story.source_type === 'meeting';
const when = story.occurs_at;
const timeLabel = !when
  ? ''
  : isMeeting
    ? formatCalendarDate(when)  // datum-utan-klockslag -- se db.ts
    : `${formatDate(when)}${!isAlert && formatTime(when) ? ` · ${formatTime(when)}` : ''}`;
---
<article class:list={['card', isAlert && 'card--alert']}>
  {timeLabel && <p class="card__when data">{timeLabel}</p>}
  <h3 class="card__title">
    <a href={`/s/${story.slug}`}>{story.title}</a>
  </h3>
  {!compact && <p class="card__body">{story.body}</p>}
</article>

<style>
.card {
  background: var(--surface);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 1.125rem 1.25rem;
}
.card--alert {
  border-color: var(--wheat);
  background: var(--wheat-tint);
}
.card__when {
  margin: 0 0 0.375rem;
  font-size: 0.75rem;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.card--alert .card__when { color: var(--wheat); }
.card__title { margin: 0 0 0.5rem; }
.card__title a { color: inherit; text-decoration: none; }
.card__title a:hover { color: var(--sky); text-decoration: underline; }
.card__body { margin: 0; font-size: 1rem; color: var(--ink); }
</style>
