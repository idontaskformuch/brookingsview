---
/**
 * Delning för en enskild story.
 *
 * Native Share (mobilens delningsmeny) när webbläsaren stödjer det -- det är
 * troligen majoriteten av besökarna på en lokal nyhetssajt. Annars raka
 * länkar (inga inbäddade tredjepartsskript -- de skulle bryta löftet på
 * /cookies om att inte spåra besökare) plus en kopiera-länk-knapp.
 */
interface Props { url: string; title: string; }
const { url, title } = Astro.props;

const fb = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
const sms = `sms:?body=${encodeURIComponent(`${title} — ${url}`)}`;
const mail = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`;
---
<div class="share" data-share-url={url} data-share-title={title}>
  <span class="share__label">Share</span>

  <button type="button" class="share__native" hidden data-native-share>
    Share
  </button>

  <a class="share__link" href={fb} target="_blank" rel="noopener" aria-label="Share on Facebook">Facebook</a>
  <a class="share__link" href={sms} aria-label="Share by text message">Text</a>
  <a class="share__link" href={mail} aria-label="Share by email">Email</a>
  <button type="button" class="share__link" data-copy-link aria-label="Copy link">Copy link</button>
</div>

<style>
.share {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.625rem;
  margin-top: 1.5rem;
}
.share__label {
  font-family: var(--font-ui);
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-soft);
  margin-right: 0.125rem;
}
.share__link, .share__native {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  padding: 0.375rem 0.75rem;
  border-radius: 4px;
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--ink);
  text-decoration: none;
  cursor: pointer;
}
.share__link:hover, .share__native:hover { border-color: var(--sky); color: var(--sky); }
.share__native { background: var(--sky); border-color: var(--sky); color: var(--surface); }
.share__native:hover { color: var(--surface); opacity: 0.9; }
</style>

<script>
  // Progressiv förbättring: visa native-knappen bara om API:t finns, dölj
  // annars helt istället för en knapp som inte gör något.
  document.querySelectorAll<HTMLElement>('[data-share-url]').forEach((root) => {
    const url = root.dataset.shareUrl!;
    const title = root.dataset.shareTitle!;
    const nativeBtn = root.querySelector<HTMLButtonElement>('[data-native-share]');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-copy-link]');

    if (nativeBtn && typeof navigator.share === 'function') {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', () => {
        navigator.share({ title, url }).catch(() => {
          /* användaren avbröt -- inget att göra */
        });
      });
    }

    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = original; }, 1800);
      } catch {
        /* clipboard-API otillgängligt (t.ex. osäker kontext) -- länken finns i adressfältet */
      }
    });
  });
</script>
