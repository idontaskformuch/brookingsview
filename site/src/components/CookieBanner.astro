---
/**
 * Cookie-samtycke, byggd innan den strikt behövs.
 *
 * Sajten sätter inga spårningscookies idag (se /privacy och /cookies), så
 * valet styr ingenting ÄN -- men det sparas redan nu (localStorage +
 * window.bvConsent), så när AdSense-kod en dag ska villkoras av samtycke
 * finns kroken på plats. Ingen ombyggnad krävs då, bara ett villkor runt
 * annonsskriptet som läser samma flagga.
 *
 * Ren vanilla JS, inget klientbibliotek -- konsekvent med resten av sajten,
 * som medvetet inte kör tunga ramverk för enkla saker.
 */
---
<div id="cookie-banner" class="banner" role="region" aria-label="Cookie notice" hidden>
  <div class="banner__inner">
    <p>
      Brookings View doesn't use tracking cookies today. If that changes, we'll
      ask again — this just lets us remember your choice.
      <a href="/cookies">Read more</a>
    </p>
    <div class="banner__actions">
      <button type="button" data-consent="declined">Decline</button>
      <button type="button" data-consent="accepted" class="banner__accept">Okay</button>
    </div>
  </div>
</div>

<style>
.banner {
  position: fixed;
  inset-inline: 0;
  bottom: 0;
  z-index: 40;
  background: var(--surface);
  border-top: 1px solid var(--rule);
  box-shadow: 0 -4px 16px rgba(25, 23, 19, 0.08);
}
.banner__inner {
  max-width: var(--measure);
  margin-inline: auto;
  padding: 0.875rem 1.25rem;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem 1.5rem;
}
.banner p {
  margin: 0;
  font-size: 0.875rem;
  color: var(--ink-soft);
  max-width: 40rem;
}
.banner p a { color: var(--navy); }
.banner__actions { display: flex; gap: 0.625rem; flex-shrink: 0; }
.banner button {
  font-family: var(--font-display);
  font-size: 0.875rem;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--ink);
  cursor: pointer;
}
.banner__accept { background: var(--navy); border-color: var(--navy); color: var(--surface); }
.banner button:hover { opacity: 0.85; }
</style>

<script>
  const KEY = 'bv_cookie_consent';
  const banner = document.getElementById('cookie-banner');

  function readConsent(): { choice: string; ts: number } | null {
    try {
      const raw = localStorage.getItem(KEY);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null; // privat läge / lagring blockerad -- visa bannern, fråga igen
    }
  }

  function setConsent(choice: 'accepted' | 'declined') {
    const record = { choice, ts: Date.now() };
    try {
      localStorage.setItem(KEY, JSON.stringify(record));
    } catch {
      /* lagring otillgänglig -- valet gäller ändå för det här sidladdningen */
    }
    (window as any).bvConsent = choice;
    window.dispatchEvent(new CustomEvent('bv:consent', { detail: record }));
  }

  const existing = readConsent();
  if (existing) {
    (window as any).bvConsent = existing.choice;
  } else if (banner) {
    banner.hidden = false;
  }

  banner?.querySelectorAll('button[data-consent]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const choice = btn.getAttribute('data-consent') as 'accepted' | 'declined';
      setConsent(choice);
      banner.hidden = true;
    });
  });
</script>
