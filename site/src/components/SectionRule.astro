---
/** Sektionsrubrik i tidningsstil: tjock överlinje, spärrad versaletikett.
 *  Etiketten anger tidshorisont, inte ämne -- sajtens fråga handlar om när. */
interface Props { label: string; href?: string; }
const { label, href } = Astro.props;
---
<div class="sec">
  <h2 class="sec__label">{label}</h2>
  {href && <a class="sec__more" href={href}>All &rarr;</a>}
</div>

<style>
.sec {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  border-top: 2px solid var(--rule-strong);
  margin: 2.25rem 0 0.875rem;
  padding-top: 0.4375rem;
}
.sec__label {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  line-height: 1;
}
.sec__more {
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
}
.sec__more { color: var(--accent); }
.sec__more:hover { text-decoration: underline; }
</style>
