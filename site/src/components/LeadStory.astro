---
/** Ettan. Dominerar sidan i skala -- det är så en tidning uttrycker redaktionell
 *  bedömning visuellt, i stället för att ge varje post lika stor vikt. */
import type { Story } from '../lib/db';
import { formatDate, formatTime, formatCalendarDate, CATEGORY_LABELS } from '../lib/db';

interface Props { story: Story; }
const { story } = Astro.props;

const isMeeting = story.source_type === 'meeting';
const isAlert = story.source_type === 'alert';
// Se StoryCard.astro för samma resonemang: byline betyder Content Track-innehåll,
// och då är occurs_at inte en riktig tidsangivelse -- publiceringsdatum är rätt.
const hasByline = Boolean(story.byline);
const when = story.occurs_at;
const timeLabel = hasByline
  ? formatDate(story.published_at)
  : !when
    ? ''
    : isMeeting
      ? formatCalendarDate(when)
      : `${formatDate(when)}${!isAlert && formatTime(when) ? ` · ${formatTime(when)}` : ''}`;
const kicker = isAlert ? 'Alert' : isMeeting ? 'City hall'
  : hasByline ? (CATEGORY_LABELS[story.source_type] ?? 'Feature') : 'Events';
// Content Track-artiklar har en egen tecknad illustration (image_path) --
// scraped events/meetings har ingen och faller tillbaka på OG-kortet, precis
// som på story-sidan (s/[slug].astro).
const heroSrc = story.image_path ?? `/og/${story.slug}.png`;
// OG-korten är alltid 1200x630 -- illustrationerna har egna mått (CSS skalar
// dem ändå till width:100%/height:auto), så hårdkodade attribut skulle bara
// ge en missvisande aspect-ratio-hint för dem.
const heroDims = story.image_path ? {} : { width: 1200, height: 630 };
---
<article class="lead">
  <p class="lead__kicker">
    <span class="kicker">{kicker}</span>
    {timeLabel && <span class="lead__when data">{timeLabel}</span>}
  </p>
  <a class="lead__image-link" href={`/s/${story.slug}`} tabindex="-1" aria-hidden="true">
    <img class="lead__image" src={heroSrc} {...heroDims}
         alt="" loading="eager" />
  </a>
  <h2 class="lead__title"><a href={`/s/${story.slug}`}>{story.title}</a></h2>
  <p class="lead__body">{story.body}</p>
  <a class="lead__more" href={`/s/${story.slug}`}>Read more &rarr;</a>
</article>

<style>
.lead { border-bottom: 2px solid var(--rule-strong); padding-bottom: 1.25rem; }
.lead__kicker {
  display: flex; flex-wrap: wrap; align-items: baseline;
  gap: 0.5rem 0.75rem; margin: 0 0 0.5rem;
}
.lead__when {
  font-size: 0.6875rem; letter-spacing: 0.04em;
  text-transform: uppercase; color: var(--ink-soft);
}
.lead__image-link { display: block; }
.lead__image {
  display: block;
  width: 100%;
  height: auto;
  margin: 0.875rem 0 1.125rem;
}
.lead__title {
  font-size: clamp(1.75rem, 4.2vw, 2.625rem);
  line-height: 1.05;
  margin: 0 0 0.625rem;
}
.lead__title a { color: inherit; text-decoration: none; }
.lead__title a:hover { color: var(--navy); }
.lead__body {
  margin: 0;
  font-size: 1.125rem;
  line-height: 1.55;
  max-width: 38rem;
}
.lead__more {
  display: inline-block;
  margin-top: 0.625rem;
  font-family: var(--font-ui);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
}
.lead__more { color: var(--accent); }
.lead__more:hover { text-decoration: underline; }
</style>
