---
/** Vidareläsning under en artikel. Enda syftet är att ge läsaren en naturlig
 *  nästa klick i stället för en återvändsgränd -- de flesta besökare landar via
 *  en delad länk och ser annars aldrig resten av sajten. */
import type { Story } from '../lib/db';
import { formatOccursAt, CATEGORY_LABELS } from '../lib/db';

interface Props { stories: Story[]; }
const { stories } = Astro.props;

const KICKER: Record<string, string> = {
  weekly: 'The week ahead',
  meeting: 'City hall',
  event: 'Events',
  alert: 'Alert',
};
---
{stories.length > 0 && (
  <nav class="related" aria-label="More to read">
    <h2 class="related__head">Read next</h2>
    <ul class="related__list">
      {stories.map((s) => (
        <li class="related__item">
          <p class="related__meta">
            <span class="kicker">{KICKER[s.source_type] ?? CATEGORY_LABELS[s.source_type] ?? 'Feature'}</span>
            {s.occurs_at && <span class="related__when data">{formatOccursAt(s)}</span>}
          </p>
          <a class="related__link" href={`/s/${s.slug}`}>{s.title}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
.related { margin-top: 2.5rem; border-top: 3px solid var(--rule-strong); padding-top: 0.5rem; }
.related__head {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin: 0 0 0.75rem;
}
.related__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; }
.related__item { border-bottom: 1px solid var(--rule); padding-block: 0.75rem; }
.related__item:last-child { border-bottom: 0; }
.related__meta {
  display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem 0.75rem;
  margin: 0 0 0.25rem;
}
.related__when {
  font-size: 0.6875rem; letter-spacing: 0.04em;
  text-transform: uppercase; color: var(--ink-soft);
}
.related__link {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 1.0625rem;
  line-height: 1.2;
  color: var(--ink);
  text-decoration: none;
}
.related__link:hover { color: var(--navy); text-decoration: underline; }
</style>
