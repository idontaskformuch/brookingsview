---
/** Mätarruta för strukturerad data -- väder, antal, priser. Motsvarar
 *  tidningens väderruta och börstabell: liten, tät, siffertung. */
interface Props { label: string; value: string; note?: string; }
const { label, value, note } = Astro.props;
---
<div class="tile">
  <p class="tile__label">{label}</p>
  <p class="tile__value data">{value}</p>
  {note && <p class="tile__note">{note}</p>}
</div>

<style>
.tile { border-left: 1px solid var(--rule); padding: 0 0 0 0.875rem; }
.tile__label {
  margin: 0 0 0.1875rem;
  font-family: var(--font-ui);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.tile__value { margin: 0; font-size: 1.375rem; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; }
.tile__note { margin: 0.125rem 0 0; font-size: 0.8125rem; color: var(--ink-soft); line-height: 1.35; }
</style>
