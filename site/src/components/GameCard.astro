---
import type { Game } from '../lib/db';
import { formatDate, formatTime } from '../lib/db';

interface Props { game: Game; feature?: boolean; }
const { game, feature = false } = Astro.props;
const home = game.home_away === 'home';
const sportName = game.sport === 'mbb' ? "men's basketball"
  : game.sport === 'wbb' ? "women's basketball"
  : game.sport.replace(/_/g, ' ');
---
<div class:list={['game', feature && 'game--feature']}>
  <p class="game__meta data">{home ? 'Home' : 'Away'} · {sportName}</p>
  <p class="game__title">Jackrabbits {home ? 'vs' : 'at'} {game.opponent}</p>
  <p class="game__when data">
    {formatDate(game.starts_at)}{game.starts_at && ` · ${formatTime(game.starts_at)}`}
    {game.venue && <><br />{game.venue}</>}
  </p>
  {game.result && <p class="game__result data">Final: {game.result}</p>}
</div>

<style>
.game {
  background: var(--surface);
  border: 1px solid var(--rule);
  border-radius: 4px;
  padding: 1.125rem 1.25rem;
}
.game--feature { background: var(--sky-tint); border-color: var(--sky); }
.game__meta {
  margin: 0 0 0.375rem;
  font-size: 0.75rem;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.game--feature .game__meta { color: var(--sky); }
.game__title {
  margin: 0 0 0.375rem;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.125rem;
  letter-spacing: -0.01em;
}
.game__when { margin: 0; font-size: 0.8125rem; color: var(--ink-soft); line-height: 1.5; }
.game__result { margin: 0.5rem 0 0; font-size: 0.875rem; font-weight: 500; }
</style>
