---
/**
 * Sidmallen: designsystem, tidningshuvud, skyltremsa, footer.
 *
 * Omarbetad efter att den första versionen läste som en produktsida snarare än
 * en tidning. Sajten ersätter Brookings Register, som lade ner 2025 -- den ska
 * se ut som en redaktion, inte som en dashboard.
 *
 * Tre principer, lånade från riktiga dagstidningar:
 *   TÄTHET      många rubriker ovanför vecket, inte fyra luftiga kort
 *   HIERARKI    en etta som dominerar, sedan fallande skala -- redaktionell
 *               bedömning uttryckt visuellt
 *   LINJER      hårfina streck delar av innehåll, inte kortramar. Inga rundade
 *               hörn någonstans.
 *
 * Typografin är omvänd mot första versionen: Newsreader (designad för nyheter)
 * bär rubrikerna, grotesken är degraderad till kickers och metadata.
 */
import { getSignData, countdown } from '../lib/db';
import { siteConfig } from '../lib/site-config';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  /** Slug att hämta delningsbild för. Utelämnad -> sajtens standardbild. */
  ogSlug?: string;
}

const {
  title,
  description = siteConfig.description,
  wide = false,
  ogSlug,
} = Astro.props;

const sign = await getSignData();
const canonical = new URL(Astro.url.pathname, Astro.site ?? siteConfig.siteUrl);
const ogImage = new URL(`/og/${ogSlug ?? 'default'}.png`, Astro.site ?? siteConfig.siteUrl).href;
const now = new Date();
const year = now.getFullYear();
// Datumraden byggs om varje timme tillsammans med resten av sajten.
const dateline = now.toLocaleDateString('en-US', {
  weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
  timeZone: siteConfig.timezone,
});

const isBrookings = siteConfig.townId === 'brookings_sd';
const isMorenoValley = siteConfig.townId === 'moreno_valley_ca';
const nav = [
  { href: '/events', label: 'Events' },
  ...(isBrookings ? [{ href: '/jackrabbits', label: 'Jackrabbits' }] : []),
  { href: '/city-hall', label: 'City hall' },
  ...(isBrookings ? [{ href: '/farm-report', label: 'Farm report' }] : []),
  ...(isMorenoValley ? [{ href: '/home-sales', label: 'Home sales' }] : []),
  { href: '/reviews', label: 'Reviews' },
  { href: '/recipes', label: 'Recipes' },
  { href: '/editorials', label: 'Editorials' },
  { href: '/columns', label: 'Columns' },
  { href: '/weather', label: 'Weather' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteConfig.siteName} />
<meta property="og:url" content={canonical.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="alternate" type="application/rss+xml" title={siteConfig.siteName} href="/rss.xml" />

<link rel="manifest" href="/manifest.webmanifest" />
<meta name="theme-color" content="#0b2e55" />
<link rel="apple-touch-icon" href="/icon-192.png" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={siteConfig.siteName} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&family=IBM+Plex+Mono:wght@400;500&display=swap"
/>

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  name: siteConfig.siteName,
  url: siteConfig.siteUrl,
  areaServed: { '@type': 'City', name: siteConfig.cityName, addressRegion: siteConfig.stateAbbr, addressCountry: 'US' },
})} />

<style is:global>
:root {
  --paper: #f4f6f7;
  --surface: #ffffff;
  --ink: #14120f;
  --ink-soft: #4d5862;
  /* Marinblå bär struktur och förtroende (12.6:1 mot papperet).
     Orange är enbart CTA -- "läs mer", knappar, aktiva lägen.
     Rött enbart varningar, skilt från CTA så en värmevarning aldrig ser ut
     som en länk. Kontrastvärden kontrollerade mot WCAG AA. */
  --navy: #0b2e55;
  --navy-tint: #e7edf4;
  --accent: #c2410c;
  --accent-tint: #fbede4;
  --alert: #b91c1c;
  --alert-tint: #d3e2f2;
  --rule: #c9d3da;
  --rule-strong: #14120f;

  --font-head: 'Newsreader', Georgia, 'Times New Roman', serif;
  --font-ui: 'Bricolage Grotesque', system-ui, sans-serif;
  --font-data: 'IBM Plex Mono', ui-monospace, monospace;

  --measure: 74rem;
  --measure-narrow: 40rem;
}

*, *::before, *::after { box-sizing: border-box; }

body {
  margin: 0;
  background: var(--paper);
  color: var(--ink);
  font-family: var(--font-head);
  font-size: 1.0625rem;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

/* Rubriker: serif, tight, tung. Tidningsröst. */
h1, h2, h3 {
  font-family: var(--font-head);
  font-weight: 700;
  letter-spacing: -0.015em;
  line-height: 1.08;
  margin: 0;
  text-wrap: balance;
}
h1 { font-size: clamp(2rem, 5vw, 3rem); }
h2 { font-size: 1.5rem; }
h3 { font-size: 1.125rem; font-weight: 600; }

a { color: var(--navy); text-underline-offset: 2px; }

:focus-visible { outline: 2px solid var(--navy); outline-offset: 2px; }

.shell {
  max-width: var(--measure);
  margin-inline: auto;
  padding-inline: 1.25rem;
}
.shell--narrow { max-width: var(--measure-narrow); }

.skip {
  position: absolute; left: -9999px;
  background: var(--ink); color: var(--paper);
  padding: 0.75rem 1rem; z-index: 10;
}
.skip:focus { left: 1rem; top: 1rem; }

.data { font-family: var(--font-data); font-variant-numeric: tabular-nums; }

/* Kicker: liten, spärrad versal etikett över en rubrik. Tidningskonvention. */
.kicker {
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--navy);
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
</style>

<style>
/* --- Tidningshuvud ------------------------------------------------------ */
.masthead { background: var(--surface); border-bottom: 3px solid var(--rule-strong); }

.masthead__name {
  display: block;
  padding-block: 1.5rem 0.75rem;
  text-align: center;
  font-family: var(--font-head);
  font-weight: 700;
  font-size: clamp(2.25rem, 7vw, 3.75rem);
  letter-spacing: -0.03em;
  line-height: 1;
  color: var(--ink);
  text-decoration: none;
}
.masthead__name em { font-style: normal; color: var(--navy); }

.dateline {
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  padding-block: 0.4375rem;
  text-align: center;
  font-family: var(--font-ui);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-soft);
}

.nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0 1.75rem;
  padding-block: 0.625rem;
}
.nav a {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding-block: 0.125rem;
}
.nav a:hover { color: var(--navy); }
.nav a[aria-current='page'] { box-shadow: inset 0 -3px 0 var(--navy); }

/* --- Skyltremsan: nu en ticker ------------------------------------------ */
.sign {
  background: var(--navy);
  color: #fff;
  border-bottom: 1px solid var(--rule-strong);
}
/* Rött är ENDAST en accent -- tickern fylls aldrig röd, den förblir navy.
   Det signalerar akut genom TEXTFÄRG på varningsraden, inte genom en stor
   röd yta. Korallfärgen (inte --alert direkt) väljs för att klara kontrast
   mot navy -- ren --alert-röd gav bara 2.11:1 på mörk botten, under AA. */
.sign__item--alert { color: #ff7a5c; font-weight: 600; }
.sign__inner {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem 1.75rem;
  padding-block: 0.5rem;
  font-family: var(--font-data);
  font-size: 0.75rem;
  letter-spacing: 0.02em;
  font-variant-numeric: tabular-nums;
}
.sign__item { display: inline-flex; align-items: baseline; gap: 0.4rem; }
.sign__item::before {
  content: '';
  width: 4px; height: 4px;
  background: currentColor;
  border-radius: 50%;
  transform: translateY(-2px);
}
.sign__item:first-child::before { display: none; }

main { padding-block: 1.75rem 3.5rem; }

/* --- Footer ------------------------------------------------------------- */
.colophon {
  border-top: 3px solid var(--rule-strong);
  background: var(--surface);
  padding-block: 1.75rem 2.25rem;
  font-size: 0.9375rem;
  color: var(--ink-soft);
}
.colophon__links {
  display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem;
  margin-bottom: 1rem;
  font-family: var(--font-ui);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.colophon__links a { color: var(--ink); text-decoration: none; }
.colophon__links a:hover { color: var(--navy); text-decoration: underline; }
.colophon p { margin: 0; max-width: 44rem; font-size: 0.9375rem; }
</style>
</head>

<body>
<a class="skip" href="#main">Skip to content</a>

<header class="masthead">
  <div class="shell">
    <a class="masthead__name" href="/">{siteConfig.brandLead} <em>{siteConfig.brandTail}</em></a>
  </div>
  <div class="dateline">{dateline} &middot; {siteConfig.cityName}, {siteConfig.stateName}</div>
  <div class="shell">
    <nav class="nav" aria-label="Sections">
      {nav.map((item) => (
        <a href={item.href} aria-current={path.startsWith(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<div class="sign">
  <div class="shell sign__inner">
    {sign.temp !== null && (
      <span class="sign__item">
        {Math.round(sign.temp)}&deg;{sign.unit}{sign.conditions && <>&nbsp;{sign.conditions.toLowerCase()}</>}
      </span>
    )}
    {sign.alert && <span class="sign__item sign__item--alert">{sign.alert}</span>}
    {sign.eventsToday > 0 && (
      <span class="sign__item">{sign.eventsToday} {sign.eventsToday === 1 ? 'event' : 'events'} today</span>
    )}
    {sign.nextGame?.starts_at && (
      <span class="sign__item">
        Jacks {sign.nextGame.home_away === 'home' ? 'vs' : 'at'} {sign.nextGame.opponent} {countdown(sign.nextGame.starts_at)}
      </span>
    )}
  </div>
</div>

<main id="main">
  <div class:list={['shell', !wide && 'shell--narrow']}>
    <slot />
  </div>
</main>

<footer class="colophon">
  <div class="shell">
    <nav class="colophon__links" aria-label="About this site">
      <a href="/about">About</a>
      <a href="/how-we-gather-this">How we gather this</a>
      <a href="/contact">Contact</a>
      <a href="/privacy">Privacy</a>
      <a href="/cookies">Cookies</a>
      <a href="/rss.xml">RSS</a>
    </nav>
    <p>
      {siteConfig.sourceBlurb} Every item
      links to its original source. Corrections are welcome.
    </p>
    <p class="data" style="margin-top:0.75rem; font-size:0.75rem;">&copy; {year} {siteConfig.siteName}</p>
  </div>
</footer>

<CookieBanner />

<script is:inline>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  });
}
</script>
</body>
</html>
